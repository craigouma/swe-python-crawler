# Copy to .env and fill in values.

# ── ReliefWeb API ────────────────────────────────────────────────────
# Register a free appname at: https://apidoc.reliefweb.int/parameters#appname
RELIEFWEB_APPNAME=your-approved-appname-here

# ── Google Sheets ────────────────────────────────────────────────────
# Absolute path to your service account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# The long ID from the Sheets URL: /spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here

# Worksheet tab name to write jobs into (created automatically if absent)
GOOGLE_WORKSHEET_NAME=Jobs

# ── Gemini LLM Matching ──────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
